<%
const basePrice = Number(product.base_price || 0);
const salePrice = Number(product.sale_price || 0);
const hasDiscount = basePrice > 0 && salePrice > 0 && salePrice < basePrice;
const discountPercent = hasDiscount ? Math.round(((basePrice - salePrice) / basePrice) * 100) : 0;
const safeReviews = typeof reviews !== 'undefined' && Array.isArray(reviews) ? reviews : [];
%>

<section class="catalog-content product-detail-section">
    <nav class="breadcrumb-nav" aria-label="Навігація">
        <a href="/">Головна</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <a href="/?category_id=<%= product.category_id %>"><%= product.category_name %></a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <span class="breadcrumb-current"><%= product.name %></span>
    </nav>

    <div class="product-detail-grid">
        <div class="product-detail-image-wrap">
            <% if (discountPercent > 0) { %>
                <span class="discount-badge discount-badge--large"><%= discountPercent %>%</span>
            <% } %>
            <% if (product.image_url) { %>
                <img src="<%= product.image_url %>" alt="<%= product.name %>" class="product-detail-image" />
            <% } else { %>
                <div class="product-detail-image product-detail-image--placeholder">Немає фото</div>
            <% } %>
        </div>

        <div class="product-detail-info">
            <h1 class="product-detail-title"><%= product.name %></h1>

            <p class="product-detail-price">
                <% if (hasDiscount) { %>
                    <span class="old-price"><%= basePrice.toLocaleString('uk-UA') %> грн</span>
                <% } %>
                <strong><%= salePrice.toLocaleString('uk-UA') %> грн</strong>
            </p>

            <p class="product-detail-meta">
                Категорія: <a href="/?category_id=<%= product.category_id %>"><%= product.category_name %></a>
            </p>

            <p class="product-detail-meta">
                <% if (Number(product.stock_quantity) > 0) { %>
                    В наявності: <%= product.stock_quantity %> <%= product.unit_type || 'шт' %>
                <% } else { %>
                    Немає в наявності
                <% } %>
            </p>

            <p class="product-detail-order">
                <% if (Number(product.stock_quantity) > 0) { %>
                    <a class="product-order-btn" href="/checkout?product_id=<%= product.id %>">Замовити</a>
                <% } else { %>
                    <button class="product-order-btn" type="button" disabled>Замовити</button>
                <% } %>
            </p>

            <% if (product.description && String(product.description).trim() !== '') { %>
                <div class="product-detail-desc">
                    <%= product.description %>
                </div>
            <% } %>

            <p class="product-detail-back">
                <a href="/">← До каталогу</a>
            </p>
        </div>
    </div>

    <div class="product-reviews-wrap">
        <div class="product-reviews-layout">
            <div class="product-reviews-col product-reviews-col--form">
                <% if (currentUser) { %>
                    <h2 class="product-review-form-title">Ваш відгук</h2>
                    <form class="product-review-form" method="post" action="/product/<%= product.id %>/reviews">
                        <textarea
                            id="review-comment"
                            class="product-review-textarea"
                            name="comment"
                            rows="4"
                            maxlength="2000"
                            required
                            minlength="2"
                            placeholder="Напиши враження про товар..."
                        ></textarea>
                        <button class="product-review-submit" type="submit">Надіслати відгук</button>
                    </form>
                <% } else { %>
                    <p class="product-review-login-hint">
                        <a href="/login">Увійди</a>, щоб залишити відгук.
                    </p>
                <% } %>
            </div>
            <div class="product-reviews-col product-reviews-col--list">
                <h2 class="product-reviews-title">Відгуки</h2>
                <% if (safeReviews.length === 0) { %>
                    <p class="product-reviews-empty">Поки немає відгуків.</p>
                <% } else { %>
                    <ul class="product-reviews-list">
                        <% for (const rev of safeReviews) { %>
                            <% const revDate = rev.createdAt || rev.createdat; %>
                            <li class="product-review-item">
                                <p class="product-review-meta">
                                    <strong><%= rev.first_name %> <%= rev.last_name %></strong>
                                    <% if (rev.rating != null && rev.rating !== '') { %>
                                        · оцінка <%= rev.rating %>/5
                                    <% } %>
                                    <% if (revDate) { %>
                                        · <%= new Date(revDate).toLocaleString('uk-UA') %>
                                    <% } %>
                                </p>
                                <% if (rev.comment && String(rev.comment).trim() !== '') { %>
                                    <p class="product-review-body"><%= rev.comment %></p>
                                <% } %>
                            </li>
                        <% } %>
                    </ul>
                <% } %>
            </div>
        </div>
    </div>
</section>
