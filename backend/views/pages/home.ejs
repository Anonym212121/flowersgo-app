<%
const safeSelectedCategoryId = typeof selectedCategoryId !== 'undefined' ? selectedCategoryId : null;
const safeSearchQuery = typeof searchQuery !== 'undefined' && typeof searchQuery === 'string' ? searchQuery : '';
const safeCategories = typeof categories !== 'undefined' && Array.isArray(categories) ? categories : [];
const safeProducts = typeof products !== 'undefined' && Array.isArray(products) ? products : [];
const safeHitProducts = typeof hitProducts !== 'undefined' && Array.isArray(hitProducts) ? hitProducts : [];
const safeHomeSections = typeof homeSections !== 'undefined' && Array.isArray(homeSections) ? homeSections : [];
const hasFeaturedBlocks = safeHitProducts.length > 0 || safeHomeSections.length > 0;
const safeRecentDelivery = typeof recentDelivery !== 'undefined' && recentDelivery ? recentDelivery : null;
const isCatalogHome = !safeSelectedCategoryId && !safeSearchQuery;
const sortCats = (a, b) => {
    const oa = Number(a.sort_order || 0);
    const ob = Number(b.sort_order || 0);
    if (oa !== ob) {
        return oa - ob;
    }
    return Number(a.id) - Number(b.id);
};
const parentCategories = safeCategories.filter((item) => !item.parent_id).sort(sortCats);
const subCategories = safeCategories.filter((item) => item.parent_id);
let selectedCategoryLabel = 'Усі товари';
if (safeSelectedCategoryId) {
    const selectedCat = safeCategories.find((item) => Number(item.id) === Number(safeSelectedCategoryId));
    if (selectedCat && selectedCat.name) {
        selectedCategoryLabel = selectedCat.name;
    }
}
%>

<div class="catalog-layout <%= isCatalogHome ? 'catalog-layout--home' : 'catalog-layout--filtered' %>">
    <aside class="catalog-sidebar">
        <h3>Категорії</h3>

        <ul class="category-list">
            <li>
                <a href="/" class="catalog-category-nav <%= !safeSelectedCategoryId ? 'active' : '' %>" data-category-id="">Усі товари</a>
            </li>

            <% for (const parent of parentCategories) { %>
                <% const nested = subCategories.filter(item => Number(item.parent_id) === Number(parent.id)).sort(sortCats); %>
                <% if (nested.length > 0) { %>
                    <li class="category-parent category-parent--flyout">
                        <a
                            href="/?category_id=<%= parent.id %>"
                            class="category-parent-link catalog-category-nav <%= Number(safeSelectedCategoryId) === Number(parent.id) ? 'active' : '' %>"
                            data-category-id="<%= parent.id %>"
                        >
                            <span class="category-parent-label"><%= parent.name %></span>
                            <span class="category-chevron" aria-hidden="true">›</span>
                        </a>
                        <div class="category-flyout" role="navigation" aria-label="Підкатегорії: <%= parent.name %>">
                            <div class="category-flyout-grid">
                                <% for (const sub of nested) { %>
                                    <a
                                        href="/?category_id=<%= sub.id %>"
                                        class="category-flyout-item catalog-category-nav <%= Number(safeSelectedCategoryId) === Number(sub.id) ? 'active' : '' %>"
                                        data-category-id="<%= sub.id %>"
                                    >
                                        <span class="category-flyout-thumb">
                                            <% if (sub.image_url) { %>
                                                <img src="<%= sub.image_url %>" alt="<%= sub.name %>">
                                            <% } %>
                                        </span>
                                        <span class="category-flyout-text"><%= sub.name %></span>
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    </li>
                <% } else { %>
                    <li class="category-parent">
                        <a
                            href="/?category_id=<%= parent.id %>"
                            class="catalog-category-nav <%= Number(safeSelectedCategoryId) === Number(parent.id) ? 'active' : '' %>"
                            data-category-id="<%= parent.id %>"
                        >
                            <%= parent.name %>
                        </a>
                    </li>
                <% } %>
            <% } %>
        </ul>

        <% if (safeRecentDelivery) { %>
            <div class="catalog-recent-delivery">
                <h3 class="catalog-recent-delivery__title"><%= safeRecentDelivery.title %></h3>
                <%- include('../partials/catalog-recent-delivery', { item: safeRecentDelivery }) %>
            </div>
        <% } %>

        <% if (isCatalogHome) { %>
            <div class="catalog-sidebar-constructor">
                <a href="/constructor" class="catalog-sidebar-constructor__link" aria-label="Перейти до конструктора букетів">
                    <img
                        class="catalog-sidebar-constructor__image"
                        src="/images/constructor-sidebar-banner.png"
                        alt="Конструктор букетів"
                        loading="lazy"
                        decoding="async"
                    />
                </a>
            </div>
        <% } %>
    </aside>

    <section class="catalog-content">
        <div class="catalog-categories-phone">
            <button
                type="button"
                class="catalog-categories-phone-btn"
                id="catalog-categories-phone-btn"
                aria-expanded="false"
                aria-controls="catalog-categories-phone-panel"
            >
                <span class="catalog-categories-phone-btn-icon" aria-hidden="true">☰</span>
                <span class="catalog-categories-phone-btn-text">
                    <span class="catalog-categories-phone-btn-label">Категорія</span>
                    <span class="catalog-categories-phone-btn-value" id="catalog-categories-phone-current"><%= selectedCategoryLabel %></span>
                </span>
                <span class="catalog-categories-phone-btn-chevron" aria-hidden="true">▼</span>
            </button>

            <div class="catalog-categories-phone-panel" id="catalog-categories-phone-panel" hidden>
                <button type="button" class="catalog-categories-phone-backdrop" data-phone-categories-close aria-label="Закрити категорії"></button>
                <div class="catalog-categories-phone-sheet" role="dialog" aria-label="Категорії товарів">
                    <div class="catalog-categories-phone-sheet-head">
                        <h3>Категорії</h3>
                        <button type="button" class="catalog-categories-phone-close" data-phone-categories-close aria-label="Закрити">×</button>
                    </div>
                    <div class="catalog-categories-phone-sheet-body">
                        <a
                            href="/"
                            class="catalog-categories-phone-link catalog-category-nav <%= !safeSelectedCategoryId ? 'active' : '' %>"
                            data-category-id=""
                            data-category-label="Усі товари"
                        >Усі товари</a>

                        <% for (const parent of parentCategories) { %>
                            <% const nested = subCategories.filter((item) => Number(item.parent_id) === Number(parent.id)).sort(sortCats); %>
                            <% if (nested.length > 0) { %>
                                <div class="catalog-categories-phone-group">
                                    <a
                                        href="/?category_id=<%= parent.id %>"
                                        class="catalog-categories-phone-link catalog-categories-phone-link--parent catalog-category-nav <%= Number(safeSelectedCategoryId) === Number(parent.id) ? 'active' : '' %>"
                                        data-category-id="<%= parent.id %>"
                                        data-category-label="<%= parent.name %>"
                                    ><%= parent.name %></a>
                                    <% for (const sub of nested) { %>
                                        <a
                                            href="/?category_id=<%= sub.id %>"
                                            class="catalog-categories-phone-link catalog-categories-phone-link--sub catalog-category-nav <%= Number(safeSelectedCategoryId) === Number(sub.id) ? 'active' : '' %>"
                                            data-category-id="<%= sub.id %>"
                                            data-category-label="<%= sub.name %>"
                                        ><%= sub.name %></a>
                                    <% } %>
                                </div>
                            <% } else { %>
                                <a
                                    href="/?category_id=<%= parent.id %>"
                                    class="catalog-categories-phone-link catalog-category-nav <%= Number(safeSelectedCategoryId) === Number(parent.id) ? 'active' : '' %>"
                                    data-category-id="<%= parent.id %>"
                                    data-category-label="<%= parent.name %>"
                                ><%= parent.name %></a>
                            <% } %>
                        <% } %>

                        <% if (isCatalogHome) { %>
                            <a href="/constructor" class="catalog-sidebar-constructor__link catalog-categories-phone-constructor" aria-label="Перейти до конструктора букетів">
                                <img
                                    class="catalog-sidebar-constructor__image"
                                    src="/images/constructor-sidebar-banner.png"
                                    alt="Конструктор букетів"
                                    loading="lazy"
                                    decoding="async"
                                />
                            </a>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <header class="catalog-hero">
            <div class="catalog-hero__content">
                <p class="catalog-hero__eyebrow">✿ Доставка квітів по місту</p>
                <% if (selectedCategoryLabel === 'Усі товари') { %>
                    <h1 class="catalog-hero__title">Обери свіжий букет</h1>
                    <p class="catalog-hero__lead">Свіжі квіти та букети — доставимо у зручний для тебе час</p>
                <% } else { %>
                    <h1 class="catalog-hero__title"><%= selectedCategoryLabel %></h1>
                    <p class="catalog-hero__lead">Замов онлайн — зберемо букет перед відправкою</p>
                <% } %>
            </div>
            <ul class="catalog-hero__perks">
                <li>Доставка від 2 год</li>
                <li>Свіжий зріз</li>
                <li>LiqPay / готівка</li>
            </ul>
        </header>

        <div class="catalog-toolbar">
            <form class="catalog-search" method="get" action="/" role="search">
                <% if (safeSelectedCategoryId) { %>
                    <input type="hidden" name="category_id" value="<%= safeSelectedCategoryId %>" />
                <% } %>
                <label class="catalog-search-label" for="catalog-q">Пошук товарів</label>
                <div class="catalog-search-row">
                    <input
                        id="catalog-q"
                        class="catalog-search-input"
                        type="search"
                        name="q"
                        value="<%= safeSearchQuery %>"
                        placeholder="Я шукаю..."
                        autocomplete="off"
                    />
                    <button class="catalog-search-btn" type="submit">Шукати</button>
                </div>
            </form>
        </div>

        <div id="catalog-hit-root">
            <% if (isCatalogHome && safeHitProducts.length > 0) { %>
                <section class="catalog-hit-section">
                    <h2 class="catalog-section-title">Хіт продажів</h2>
                    <div class="products-grid">
                        <% for (const product of safeHitProducts) { %>
                            <%- include('../partials/catalog-product-card', {
                                product,
                                showHitBadge: true,
                                wishlistProductIds: typeof wishlistProductIds !== 'undefined' ? wishlistProductIds : []
                            }) %>
                        <% } %>
                    </div>
                </section>
            <% } %>
        </div>

        <div id="catalog-category-root" class="catalog-category-panel">
            <% if (!isCatalogHome) { %>
                <% if (safeProducts.length === 0) { %>
                    <p class="catalog-empty">Товари не знайдено.</p>
                <% } else { %>
                    <div class="products-grid">
                        <% for (const product of safeProducts) { %>
                            <%- include('../partials/catalog-product-card', {
                                product,
                                showHitBadge: false,
                                wishlistProductIds: typeof wishlistProductIds !== 'undefined' ? wishlistProductIds : []
                            }) %>
                        <% } %>
                    </div>
                <% } %>
            <% } %>
        </div>
    </section>

    <div id="catalog-sections-root" class="catalog-sections-stack<% if (!isCatalogHome || safeHomeSections.length === 0) { %> catalog-sections-stack--empty<% } %>">
        <% if (isCatalogHome) { %>
            <% for (const section of safeHomeSections) { %>
                <%- include('../partials/catalog-home-section', {
                    section,
                    wishlistProductIds: typeof wishlistProductIds !== 'undefined' ? wishlistProductIds : []
                }) %>
            <% } %>
        <% } %>
    </div>

    <section id="catalog-all-root" class="catalog-all-panel<% if (!isCatalogHome || safeProducts.length === 0) { %> catalog-all-panel--empty<% } %>">
        <% if (isCatalogHome) { %>
            <% if (!hasFeaturedBlocks && safeProducts.length === 0) { %>
                <p class="catalog-empty">Товари не знайдено.</p>
            <% } else if (safeProducts.length > 0) { %>
                <% if (hasFeaturedBlocks) { %>
                    <h2 class="catalog-section-title">Усі товари</h2>
                <% } %>
                <div class="products-grid products-grid--wide">
                    <% for (const product of safeProducts) { %>
                        <%- include('../partials/catalog-product-card', {
                            product,
                            showHitBadge: false,
                            wishlistProductIds: typeof wishlistProductIds !== 'undefined' ? wishlistProductIds : []
                        }) %>
                    <% } %>
                </div>
            <% } %>
        <% } %>
    </section>
</div>