<%
const safeSelectedCategoryId = typeof selectedCategoryId !== 'undefined' ? selectedCategoryId : null;
const safeCategories = typeof categories !== 'undefined' && Array.isArray(categories) ? categories : [];
const safeProducts = typeof products !== 'undefined' && Array.isArray(products) ? products : [];
%>

<div class="catalog-layout">
    <aside class="catalog-sidebar">
        <h3>Категорії</h3>

        <ul class="category-list">
            <li>
                <a href="/" class="<%= !safeSelectedCategoryId ? 'active' : '' %>">Усі товари</a>
            </li>

            <% const parentCategories = safeCategories.filter(item => !item.parent_id); %>
            <% const subCategories = safeCategories.filter(item => item.parent_id); %>

            <% for (const parent of parentCategories) { %>
                <li class="category-parent">
                    <a
                        href="/?category_id=<%= parent.id %>"
                        class="<%= Number(safeSelectedCategoryId) === Number(parent.id) ? 'active' : '' %>"
                    >
                        <%= parent.name %>
                    </a>

                    <% const nested = subCategories.filter(item => Number(item.parent_id) === Number(parent.id)); %>
                    <% if (nested.length > 0) { %>
                        <ul class="subcategory-list">
                            <% for (const sub of nested) { %>
                                <li>
                                    <a
                                        href="/?category_id=<%= sub.id %>"
                                        class="<%= Number(safeSelectedCategoryId) === Number(sub.id) ? 'active' : '' %>"
                                    >
                                        <%= sub.name %>
                                    </a>
                                </li>
                            <% } %>
                        </ul>
                    <% } %>
                </li>
            <% } %>
        </ul>
    </aside>

    <section class="catalog-content">
        <h1>Каталог товарів</h1>

        <% if (safeProducts.length === 0) { %>
            <p>Товари не знайдено.</p>
        <% } else { %>
            <div class="products-grid">
                <% for (const product of safeProducts) { %>
                    <article class="product-card">
                        <div class="product-image-wrap">
                            <% if (product.image_url) { %>
                                <img src="<%= product.image_url %>" alt="<%= product.name %>" class="product-image" />
                            <% } else { %>
                                <div class="product-image product-image--placeholder">Немає фото</div>
                            <% } %>
                        </div>

                        <h4 class="product-title"><%= product.name %></h4>

                        <% if (product.category_name) { %>
                            <p class="product-category"><%= product.category_name %></p>
                        <% } %>

                        <p class="product-description">
                            <%= product.description ? product.description.slice(0, 120) : 'Опис відсутній' %>
                            <%= product.description && product.description.length > 120 ? '...' : '' %>
                        </p>

                        <p class="product-price">
                            <% if (Number(product.sale_price) < Number(product.base_price)) { %>
                                <span class="old-price"><%= product.base_price %> грн</span>
                            <% } %>
                            <strong><%= product.sale_price %> грн</strong>
                        </p>

                        <p class="product-stock">
                            <% if (Number(product.stock_quantity) > 0) { %>
                                В наявності: <%= product.stock_quantity %> <%= product.unit_type || 'шт' %>
                            <% } else { %>
                                Немає в наявності
                            <% } %>
                        </p>
                    </article>
                <% } %>
            </div>
        <% } %>
    </section>
</div>