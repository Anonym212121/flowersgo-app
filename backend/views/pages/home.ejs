<%
const safeSelectedCategoryId = typeof selectedCategoryId !== 'undefined' ? selectedCategoryId : null;
const safeSearchQuery = typeof searchQuery !== 'undefined' && typeof searchQuery === 'string' ? searchQuery : '';
const safeCategories = typeof categories !== 'undefined' && Array.isArray(categories) ? categories : [];
const safeProducts = typeof products !== 'undefined' && Array.isArray(products) ? products : [];
%>

<div class="catalog-layout">
    <aside class="catalog-sidebar">
        <h3>Категорії</h3>

        <ul class="category-list">
            <li>
                <a href="/" class="<%= !safeSelectedCategoryId ? 'active' : '' %>">Усі товари</a>
            </li>

            <% const parentCategories = safeCategories.filter(item => !item.parent_id); %>
            <% const subCategories = safeCategories.filter(item => item.parent_id); %>

            <% for (const parent of parentCategories) { %>
                <% const nested = subCategories.filter(item => Number(item.parent_id) === Number(parent.id)); %>
                <% if (nested.length > 0) { %>
                    <li class="category-parent category-parent--flyout">
                        <a
                            href="/?category_id=<%= parent.id %>"
                            class="category-parent-link <%= Number(safeSelectedCategoryId) === Number(parent.id) ? 'active' : '' %>"
                        >
                            <span class="category-parent-label"><%= parent.name %></span>
                            <span class="category-chevron" aria-hidden="true">›</span>
                        </a>
                        <div class="category-flyout" role="navigation" aria-label="Підкатегорії: <%= parent.name %>">
                            <div class="category-flyout-grid">
                                <% for (const sub of nested) { %>
                                    <a
                                        href="/?category_id=<%= sub.id %>"
                                        class="category-flyout-item <%= Number(safeSelectedCategoryId) === Number(sub.id) ? 'active' : '' %>"
                                    >
                                        <span class="category-flyout-thumb" aria-hidden="true"></span>
                                        <span class="category-flyout-text"><%= sub.name %></span>
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    </li>
                <% } else { %>
                    <li class="category-parent">
                        <a
                            href="/?category_id=<%= parent.id %>"
                            class="<%= Number(safeSelectedCategoryId) === Number(parent.id) ? 'active' : '' %>"
                        >
                            <%= parent.name %>
                        </a>
                    </li>
                <% } %>
            <% } %>
        </ul>
    </aside>

    <section class="catalog-content">
        <div class="catalog-toolbar">
            <form class="catalog-search" method="get" action="/" role="search">
                <% if (safeSelectedCategoryId) { %>
                    <input type="hidden" name="category_id" value="<%= safeSelectedCategoryId %>" />
                <% } %>
                <label class="catalog-search-label" for="catalog-q">Пошук товарів</label>
                <div class="catalog-search-row">
                    <input
                        id="catalog-q"
                        class="catalog-search-input"
                        type="search"
                        name="q"
                        value="<%= safeSearchQuery %>"
                        placeholder="Введи назву товару..."
                        autocomplete="off"
                    />
                    <button class="catalog-search-btn" type="submit">Шукати</button>
                </div>
            </form>
        </div>


        <% if (safeProducts.length === 0) { %>
            <p>Товари не знайдено.</p>
        <% } else { %>
            <div class="products-grid">
                <% for (const product of safeProducts) { %>
                    <article class="product-card">
                        <div class="product-image-wrap">
                            <% const basePrice = Number(product.base_price || 0); %>
                            <% const salePrice = Number(product.sale_price || 0); %>
                            <% const hasDiscount = basePrice > 0 && salePrice > 0 && salePrice < basePrice; %>
                            <% const discountPercent = hasDiscount ? Math.round(((basePrice - salePrice) / basePrice) * 100) : 0; %>
                            <% if (discountPercent > 0) { %>
                                <span class="discount-badge"><%= discountPercent %>%</span>
                            <% } %>
                            <% if (product.image_url) { %>
                                <img src="<%= product.image_url %>" alt="<%= product.name %>" class="product-image" />
                            <% } else { %>
                                <div class="product-image product-image--placeholder">Немає фото</div>
                            <% } %>
                        </div>

                        <h4 class="product-title"><%= product.name %></h4>

                        <p class="product-price">
                            <% if (hasDiscount) { %>
                                <span class="old-price"><%= basePrice.toLocaleString('uk-UA') %> грн</span>
                            <% } %>
                            <strong><%= salePrice.toLocaleString('uk-UA') %> грн</strong>
                        </p>

                        <p class="product-stock">
                            <% if (Number(product.stock_quantity) > 0) { %>
                                В наявності: <%= product.stock_quantity %> <%= product.unit_type || 'шт' %>
                            <% } else { %>
                                Немає в наявності
                            <% } %>
                        </p>

                        <button class="product-order-btn" type="button">Замовити</button>
                    </article>
                <% } %>
            </div>
        <% } %>
    </section>
</div>