<%
const isPaid = order && order.payment_status === 'paid';
const showPayAgain = !isPaid && canPayAgain && payToken;
%>

<section class="catalog-content checkout-page">
    <h1 class="checkout-page-title">
        <% if (isPaid) { %>
            Оплату отримано
        <% } else { %>
            Оплата не завершена
        <% } %>
    </h1>

    <div class="checkout-step-card">
        <p>Замовлення #<%= order.id %></p>
        <p>Статус оплати: <strong><%= typeof paymentStatusText !== 'undefined' ? paymentStatusText : order.payment_status %></strong></p>

        <% if (isPaid) { %>
            <p>Дякуємо! Оплату зафіксовано. Замовлення очікує підтвердження адміністратора.</p>
        <% } else { %>
            <p>Оплата не пройшла або ви закрили сторінку LiqPay. Можете спробувати ще раз.</p>
            <% if (showPayAgain) { %>
                <p>
                    <a href="/payment/<%= order.id %>?t=<%= encodeURIComponent(payToken) %>" class="auth-button" data-soft-nav="false">Спробувати оплатити знову</a>
                </p>
            <% } %>
        <% } %>

        <p class="error-link-row">
            <a href="<%= isPaid ? '/cabinet?ok=payment_paid' : '/cabinet' %>" class="auth-button">До кабінету</a>
        </p>
    </div>
</section>
