<%
const checkoutUnitPrice = Number(product.sale_price || 0);
const checkoutMaxQty = Number(product.stock_quantity || 0);
const checkoutProductId = Number(product.id);
const initialItemsJson = JSON.stringify([
    { product_id: checkoutProductId, quantity: 1, unit_price: checkoutUnitPrice }
]);
const initialItemsAttr = initialItemsJson.replace(/&/g, '&amp;').replace(/"/g, '&quot;');
%>

<section class="catalog-content">
    <h1>Оформлення замовлення</h1>

    <form method="post" action="/orders" id="checkoutOrderForm" class="checkout-step1-form">
        <input type="hidden" name="total_price" id="checkoutTotalPrice" value="<%= checkoutUnitPrice %>" />
        <input type="hidden" name="items" id="checkoutItemsJson" value="<%= initialItemsAttr %>" />

        <p class="checkout-product-name"><%= product.name %></p>
        <p class="checkout-unit-price">
            <%= checkoutUnitPrice.toLocaleString('uk-UA') %> грн за <%= product.unit_type || 'шт' %>
        </p>
        <label class="auth-label checkout-qty-label">
            Кількість
            <input
                class="auth-input"
                type="number"
                id="checkoutQty"
                name="line_quantity"
                min="1"
                max="<%= checkoutMaxQty %>"
                value="1"
            />
        </label>
        <p class="checkout-line-total">
            Разом: <strong id="checkoutLineTotal"><%= checkoutUnitPrice.toLocaleString('uk-UA') %> грн</strong>
        </p>

        <h2 class="checkout-step-heading">1. Ваші дані</h2>
        <label class="auth-label">
            Email (необов'язково)
            <input class="auth-input" type="email" name="customer_email" autocomplete="email" />
        </label>
        <label class="auth-label">
            Ім'я
            <input class="auth-input" type="text" name="customer_first_name" autocomplete="given-name" required minlength="2" />
        </label>
        <label class="auth-label">
            Прізвище
            <input class="auth-input" type="text" name="customer_last_name" autocomplete="family-name" required minlength="2" />
        </label>
        <label class="auth-label">
            Номер телефону
            <input class="auth-input" type="tel" name="customer_phone" autocomplete="tel" required />
        </label>

        <div class="checkout-future-step checkout-future-step--active">
            <h2 class="checkout-step-heading">2. Кому доставити</h2>
            <fieldset class="checkout-recipient-mode">
                <legend class="sr-only">Одержувач</legend>
                <label class="checkout-radio-label">
                    <input type="radio" name="recipient_mode" value="self" checked />
                    Я одержувач
                </label>
                <label class="checkout-radio-label">
                    <input type="radio" name="recipient_mode" value="other" id="recipientModeOther" />
                    Доставити іншій особі
                </label>
            </fieldset>
            <div id="recipientOtherFields" class="checkout-recipient-other" hidden>
                <label class="auth-label">
                    Ім'я одержувача
                    <input class="auth-input" type="text" name="recipient_first_name" autocomplete="section-recipient given-name" />
                </label>
                <label class="auth-label">
                    Прізвище одержувача
                    <input class="auth-input" type="text" name="recipient_last_name" autocomplete="section-recipient family-name" />
                </label>
                <label class="auth-label">
                    Телефон одержувача
                    <input class="auth-input" type="tel" name="recipient_phone" autocomplete="section-recipient tel" />
                </label>
                <label class="auth-label">
                    Коментар до доставки (необов'язково)
                    <textarea class="auth-input" name="recipient_note" rows="2"></textarea>
                </label>
            </div>
        </div>

        <div class="checkout-future-step checkout-future-step--active">
            <h2 class="checkout-step-heading">3. Куди доставити</h2>
            <label class="auth-label">
                Адреса доставки
                <textarea
                    class="auth-input"
                    name="delivery_place"
                    rows="3"
                    required
                    minlength="8"
                    placeholder="Місто, вулиця, будинок…"
                ></textarea>
            </label>
            <label class="auth-label">
                Дата й час доставки
                <input class="auth-input" type="datetime-local" name="delivery_datetime" />
            </label>
        </div>

        <button type="submit" class="auth-button" id="checkoutSubmitOrder">Оформити замовлення</button>
    </form>

</section>

<script>
(function () {
    var q = document.getElementById('checkoutQty');
    var out = document.getElementById('checkoutLineTotal');
    var hidTotal = document.getElementById('checkoutTotalPrice');
    var hidItems = document.getElementById('checkoutItemsJson');
    if (!q || !out || !hidTotal || !hidItems) {
        return;
    }
    var pid = <%= checkoutProductId %>;
    var unit = <%= checkoutUnitPrice %>;
    var maxQ = <%= checkoutMaxQty %>;
    function upd() {
        var n = parseInt(q.value, 10);
        if (!isFinite(n) || n < 1) {
            n = 1;
        }
        if (n > maxQ) {
            n = maxQ;
        }
        q.value = String(n);
        var lineTotal = n * unit;
        out.textContent = lineTotal.toLocaleString('uk-UA') + ' грн';
        hidTotal.value = String(lineTotal);
        hidItems.value = JSON.stringify([
            { product_id: pid, quantity: n, unit_price: unit }
        ]);
    }
    q.addEventListener('input', upd);
    q.addEventListener('change', upd);
    upd();
})();

(function () {
    var panel = document.getElementById('recipientOtherFields');
    var radioOther = document.getElementById('recipientModeOther');
    if (!panel || !radioOther) {
        return;
    }
    var radios = document.querySelectorAll('input[name="recipient_mode"]');
    function sync() {
        var show = radioOther.checked;
        panel.hidden = !show;
        var reqNames = ['recipient_first_name', 'recipient_last_name', 'recipient_phone'];
        for (var i = 0; i < reqNames.length; i++) {
            var el = panel.querySelector('[name="' + reqNames[i] + '"]');
            if (el) {
                el.required = show;
            }
        }
    }
    for (var j = 0; j < radios.length; j++) {
        radios[j].addEventListener('change', sync);
    }
    sync();
})();
</script>
