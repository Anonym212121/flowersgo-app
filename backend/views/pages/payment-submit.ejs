<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="referrer" content="no-referrer" />
    <title>Оплата замовлення #<%= order.id %> — FlowersGo</title>
    <script>
        (function () {
            try {
                if (localStorage.getItem('site-theme') === 'light') {
                    document.documentElement.classList.add('theme-light');
                }
            } catch (e) {}
        })();
    </script>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/theme-light.css" />
</head>
<body class="payment-submit-body">
    <main class="catalog-content checkout-page">
        <h1 class="checkout-page-title">Оплата замовлення #<%= order.id %></h1>
        <div class="checkout-step-card">
            <p>До сплати: <strong><%= Number(order.total_amount || 0).toLocaleString('uk-UA') %> грн</strong></p>
            <% if (isSandbox) { %>
                <p class="payment-sandbox-note">Тестовий режим: гроші не списуються.</p>
            <% } %>
            <p class="payment-sandbox-note">Перенаправлення на LiqPay...</p>
            <form id="liqpayCheckoutForm" method="post" action="https://www.liqpay.ua/api/3/checkout" accept-charset="utf-8">
                <input type="hidden" name="data" id="liqpayDataField" value="" />
                <input type="hidden" name="signature" id="liqpaySignatureField" value="" />
                <button type="submit" class="auth-button checkout-submit-btn">Сплатити через LiqPay</button>
            </form>
        </div>
    </main>
    <script>
    (function () {
        var dataField = document.getElementById('liqpayDataField');
        var sigField = document.getElementById('liqpaySignatureField');
        var form = document.getElementById('liqpayCheckoutForm');
        if (!dataField || !sigField || !form) {
            return;
        }
        dataField.value = <%- JSON.stringify(liqpayData) %>;
        sigField.value = <%- JSON.stringify(liqpaySignature) %>;
        form.submit();
    })();
    </script>
</body>
</html>
